# The Halleen Machine - Configuration
# Generated by setup.py

[comfyui]
# Path to your ComfyUI installation
install_path = "D:/ComfyUI"

# ComfyUI API endpoint
api_base = "http://127.0.0.1:8188"

# Timeout for ComfyUI API calls in seconds
timeout_seconds = 300

# Where ComfyUI saves generated images
output_root = "D:/ComfyUI/output"

[paths]
# Path to model checkpoints
models = "D:/ComfyUI/models/checkpoints"

# Path to LoRA files
loras = "D:/ComfyUI/models/loras"

# Workspace for project files
workspace = "./samples"

[backups]
# Number of project backups to keep
retention = 50

# Minimum seconds between auto-backups
throttle_seconds = 300

[models]
# Default checkpoint for new projects
default_project_model = "sdXL_v10VAEFix.safetensors"

# Fast model for basic pose generation
pose_model_fast = "sdXL_v10VAEFix.safetensors"

# Expressive model for detailed pose generation
pose_model_enhanced = "obsessionIllustrious_v21.safetensors"

# ControlNet model for pose-based keyframe generation
controlnet_model = "diffusion_pytorch_model_promax.safetensors"

# Inpainting model for 2CHAR heal process
inpainting_model = "juggernautxl-inpainting.safetensors"

# 4x upscaling model
upscale_model = "4x_NMKD-Siax_200k.pth"

# Interpolation model (configured in ComfyUI node)
interpolation_model = "rife47.pth"

[advanced]
# Script to restart ComfyUI (optional, enables restart button)
restart_script = "D:/ComfyUI/start.ps1"
